# App
APP_NAME="Prescription Extraction System"
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
# Use the postgres service name in docker-compose
# DATABASE_URL=postgresql+asyncpg://rxuser:rxpassword@localhost:5432/prescription_db
# DATABASE_URL=postgresql://postgres:ivyE8xRezewv1ZPo@db.qmskbqsdokihadtxoykf.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.qmskbqsdokihadtxoykf:ivyE8xRezewv1ZPo@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres
# File storage
UPLOAD_DIR=./uploads
TEMP_DIR=./tmp
MAX_FILE_SIZE_MB=10

# VLM service (vLLM)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_TIMEOUT_SECONDS=30
VLLM_MAX_TOKENS=2000
VLLM_TEMPERATURE=0.0

# Cloud fallback
OPENAI_API_KEY=sk--
OPENAI_MODEL=gpt-4o
CLOUD_FALLBACK_ENABLED=false

# Embedding Service
# Options: local, gemini, jina
EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyAdtPWOqQyvcQxY9PyxG3l5BT8yteUB0v4
JINA_API_KEY=empty
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=3072

# Confidence thresholds
CLOUD_FALLBACK_THRESHOLD=0.70
HUMAN_REVIEW_THRESHOLD=0.60
DOCTOR_MATCH_MIN_CONFIDENCE=0.65
MEDICINE_MATCH_MIN_CONFIDENCE=0.75
